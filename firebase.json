{
  "hosting": {
    "target": "jaiful",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "supabase-schema.sql",
      "README.md",
      ".git",
      "node_modules",
      ".claude"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/about",
        "destination": "/about/index.html"
      },
      {
        "source": "/admin",
        "destination": "/admin/index.html"
      },
      {
        "source": "/claude-123",
        "destination": "/claude-123/index.html"
      },
      {
        "source": "/claude-123/success",
        "destination": "/claude-123/success/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=3600" }
        ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg|webp|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=604800" }
        ]
      }
    ]
  }
}
